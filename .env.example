# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your values
# NEVER commit your .env file to Git (it's already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose ONE: openai | anthropic | google
LLM_PROVIDER=openai

# ── LLM API Keys (only the one matching LLM_PROVIDER is required) ─────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Google Custom Search (required regardless of LLM provider) ───────────────
# How to get these:
#   1. Go to https://programmablesearchengine.google.com
#   2. Create a new search engine (search the whole web)
#   3. Copy the Search Engine ID below
#   4. Go to https://console.cloud.google.com → Enable "Custom Search API"
#   5. Create an API key and copy it below
GOOGLE_CSE_ID=your_search_engine_id_here
GOOGLE_CSE_API_KEY=your_google_api_key_here

# ── LangSmith Observability (optional but recommended) ────────────────────────
# Sign up free at https://smith.langchain.com
# This gives you a visual dashboard of every agent run
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=supply-chain-monitor
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Model Overrides (optional — uses sensible defaults if blank) ──────────────
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-haiku-20240307
GOOGLE_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.0

# ── Agent Behaviour ───────────────────────────────────────────────────────────
MAX_ITERATIONS=6
REQUIRE_APPROVAL=true

# ── Alert Destinations ────────────────────────────────────────────────────────
ALERT_EMAIL=operations@yourcompany.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
