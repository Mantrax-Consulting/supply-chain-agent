# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your values
# NEVER commit your .env file to Git (it's already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose ONE: openai | anthropic | google
LLM_PROVIDER=openai

# ── LLM API Keys (only the one matching LLM_PROVIDER is required) ─────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Tavily Search (required — sign up free at https://tavily.com) ─────────────
TAVILY_API_KEY=tvly-...

# ── LangSmith Observability (optional but recommended) ────────────────────────
# Sign up free at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=supply-chain-monitor
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Model Overrides (optional — uses sensible defaults if blank) ──────────────
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
GOOGLE_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.0

# ── Agent Behaviour ───────────────────────────────────────────────────────────
MAX_ITERATIONS=6
REQUIRE_APPROVAL=true

# ── Alert Destinations ────────────────────────────────────────────────────────
ALERT_EMAIL=operations@yourcompany.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
